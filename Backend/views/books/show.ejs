<%- include('../partials/header') %>

<div class="container">
    <div class="row">
        <div class="col-md-4">
            <img src="<%= book.coverImage %>" class="img-fluid rounded" alt="<%= book.title %>">
        </div>
        <div class="col-md-8">
            <h1><%= book.title %></h1>
            <h4 class="text-muted">by <%= book.author %></h4>
            <hr>
            <p><strong>Category:</strong> <%= book.category.name %></p>
            <p><strong>Description:</strong></p>
            <p><%= book.description %></p>
            <hr>
            <h3>$<%= book.price %></h3>
            <button class="btn btn-success btn-lg">Add to Cart</button>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
